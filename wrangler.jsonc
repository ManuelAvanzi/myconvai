{
  "name": "myconvai",
  "main": "worker.js",
  "compatibility_date": "2026-04-22",
  "assets": {
    "directory": "./public"
  },
  "kv_namespaces": [
    {
      "binding": "MYCONVAI_STORE",
      "id": "REPLACE_WITH_KV_NAMESPACE_ID"
    }
  ],
  "vars": {
    "ADMIN_USER": "admin",
    "CHAT_RATE_LIMIT_PER_MIN": "30",
    "ADMIN_RATE_LIMIT_PER_MIN": "120"
  }
}
